{
  "functions": {
    "api/ai.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/",          "destination": "/landing.html" },
    { "source": "/app",       "destination": "/app/index.html" },
    { "source": "/app/(.*)",  "destination": "/app/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options",        "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
