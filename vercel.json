{
  "functions": {
    "api/ai.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/landing", "destination": "/landing.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options",        "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
